{
  "name": "project-scaffolder",
  "version": "0.1.0",
  "description": "CLI tool to scaffold new projects from templates",
  "type": "module",
  "bin": {
    "create-project": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsup src/index.ts --format esm --shebang",
    "test": "vitest"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "inquirer": "^9.2.15",
    "chalk": "^5.3.0",
    "fs-extra": "^11.2.0",
    "handlebars": "^4.7.8"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.7",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^20.11.30",
    "tsup": "^8.0.2",
    "tsx": "^4.7.1",
    "typescript": "~5.4.3",
    "vitest": "^1.4.0"
  },
  "keywords": ["cli", "scaffold", "template", "generator"],
  "license": "MIT"
}